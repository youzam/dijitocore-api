{
  "name": "dijitotrack-api",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "dev": "npm run prisma:format && npm run prisma:validate && npm run prisma:generate && npm run prisma:migrate:dev && npm run scan:permissions && nodemon src/server.js",
    "start": "npm run prisma:format && npm run prisma:validate && npm run prisma:generate && npm run prisma:migrate:deploy && node src/server.js",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "check:locale": "node scripts/check-locale-parity.js",
    "check:locale-structure": "node scripts/check-locale-structure.js",
    "check:locale-unused": "node scripts/check-unused-locale-keys.js",
    "check:env-unused": "node scripts/check-missing-env.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "scan:permissions": "node scripts/scanPermissions.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/s3-request-presigner": "^3.1040.0",
    "@prisma/client": "^6.x",
    "@sendgrid/mail": "^8.1.6",
    "archiver": "^7.0.1",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "csvtojson": "^2.0.10",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-fileupload": "^1.5.2",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.6.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "ip-range-check": "^0.2.0",
    "joi": "^18.0.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.17.2",
    "pino": "^10.2.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "twilio": "^5.12.1",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.3",
    "prisma": "^6.x"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "eslintConfig": {
    "root": true
  }
}
