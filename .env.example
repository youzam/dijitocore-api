NODE_ENV=development

# ========================
# SERVER CONFIG
# ========================
PORT=5000


# ========================
# DATABASE
# ========================
DATABASE_URL=postgresql://username:password@localhost:5432/db_name


# ========================
# AUTHENTICATION (JWT)
# ========================
JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d


# ========================
# FRONTEND & DOMAINS
# ========================
FRONTEND_URL=http://localhost:3000
BASE_DOMAIN_COM=example.com
BASE_DOMAIN_TZ=example.co.tz


# ========================
# EMAIL CONFIG
# ========================
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@example.com
SENDGRID_API_KEY=SG.your_sendgrid_key


# ========================
# SMS CONFIG
# ========================
SMS_PROVIDER=console
SMS_FROM=your_sender_name
BEEM_API_KEY=your_beem_api_key
BEEM_SECRET=your_beem_secret


# ========================
# REDIS (CACHING / QUEUES)
# ========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=true

REDIS_URL=redis://:password@host:port


# ========================
# FIREBASE (PUSH NOTIFICATIONS)
# ========================
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"


# ========================
# WHATSAPP (TWILIO)
# ========================
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+123456789


# ========================
# PAYMENT WEBHOOK SECURITY
# ========================
PAYMENT_WEBHOOK_IP_MODE=DISABLED
PAYMENT_WEBHOOK_IPS=your_ip_list
PAYMENT_WEBHOOK_SECRET=
GATEWAY_WEBHOOK_SECRET=your_gateway_secret


# ========================
# JOB / ALERTS
# ========================
JOB_ALERT_WEBHOOK=https://your-alert-url.com/webhook


# ========================
# PAYMENT PROVIDERS
# ========================

# MPESA
MPESA_BASE_URL=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/webhooks/payments

# SELCOM
SELCOM_BASE_URL=https://apigw.selcommobile.com/sandbox
SELCOM_API_KEY=your_api_key
SELCOM_API_SECRET=your_api_secret
SELCOM_VENDOR_ID=your_vendor_id
SELCOM_CALLBACK_URL=https://yourdomain.com/webhooks/payments

# AIRTEL
AIRTEL_BASE_URL=
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_MERCHANT_ID=
AIRTEL_CALLBACK_URL=https://yourdomain.com/webhooks/payments


# ========================
# SYSTEM / JOBS
# ========================
INSTANCE_ID=server-1


# ========================
# STORAGE (FILES)
# ========================
STORAGE_PROVIDER=s3
STORAGE_PATH=uploads/

AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

AWS_S3_BUCKET_DEV=your_dev_bucket
AWS_S3_BUCKET_PROD=your_prod_bucket