//////////////////////////////////////////////////////
// DIJITOPAY — PRISMA SCHEMA 
//////////////////////////////////////////////////////

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ADMIN IMPERSONATION — Admin acting as user
//////////////////////////////////////////////////////

model AdminImpersonation {
  id           String    @id @default(uuid())
  adminId      String
  targetUserId String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?

  ip        String?
  userAgent String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([adminId])
  @@index([targetUserId])
}

//////////////////////////////////////////////////////
// ADMIN SESSION — Admin login sessions
//////////////////////////////////////////////////////

model AdminSession {
  id      String      @id @default(uuid())
  adminId String
  admin   SystemAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  ip                String?
  userAgent         String?
  deviceFingerprint String?

  refreshToken String?
  lastSeen     DateTime

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([adminId])
}

//////////////////////////////////////////////////////
// API METRIC — API performance tracking
//////////////////////////////////////////////////////

model ApiMetric {
  id              String @id @default(uuid())
  totalRequests   Int
  successRequests Int
  failedRequests  Int
  avgResponseTime Float

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// APPROVAL REQUEST — Workflow approvals
//////////////////////////////////////////////////////

model ApprovalRequest {
  id         String @id @default(uuid())
  businessId String

  type       String?
  entityType String
  entityId   String

  requestedBy String
  approvedBy  String?

  status ApprovalStatus @default(PENDING)

  reason       String?
  decisionNote String?

  resolvedAt DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([businessId])
  @@index([entityType])
  @@index([entityId])
  @@index([status])
}

//////////////////////////////////////////////////////
// AUDIT LOG — System audit trail
//////////////////////////////////////////////////////

model AuditLog {
  id String @id @default(uuid())

  businessId String?
  userId     String?
  customerId String?

  entityType String?
  entityId   String?

  action   String
  metadata Json?

  ipAddress String?
  userAgent String?

  actorType String  @default("TENANT")
  module    String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([businessId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([action])
  @@index([actorType])
}

//////////////////////////////////////////////////////
// BULK NOTIFICATION LIMIT — Weekly limits
//////////////////////////////////////////////////////

model BulkNotificationLimit {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  weekStart DateTime
  count     Int      @default(0)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([businessId, weekStart])
}

//////////////////////////////////////////////////////
// BUSINESS — Tenant entity
//////////////////////////////////////////////////////

model Business {
  id String @id @default(uuid())

  name         String
  email        String?
  phone        String?
  country      String
  businessCode String  @unique

  status         BusinessStatus @default(PENDING)
  setupCompleted Boolean        @default(false)

  users    User[]
  invites  BusinessInvite[]
  settings BusinessSettings?

  subscriptions               Subscription[]
  subscriptionPayments        SubscriptionPayment[]
  customers                   Customer[]
  notifications               Notification[]
  notificationSettings        NotificationSetting[]
  notificationTemplates       NotificationTemplate[]
  notificationEscalationRules NotificationEscalationRule[]
  bulkNotificationLimits      BulkNotificationLimit[]
  subscriptionUsages          SubscriptionUsage[]
  subscriptionHistories       SubscriptionHistory[]

  lastActiveAt DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([country])
}

//////////////////////////////////////////////////////
// BUSINESS INVITE — User invitations
//////////////////////////////////////////////////////

model BusinessInvite {
  id String @id @default(uuid())

  email     String
  role      UserRole
  tokenHash String
  expiresAt DateTime

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([email])
}

//////////////////////////////////////////////////////
// BUSINESS SETTINGS — Tenant config
//////////////////////////////////////////////////////

model BusinessSettings {
  id String @id @default(uuid())

  businessId String @unique
  currency   String @default("TZS")
  timezone   String @default("Africa/Dar_es_Salaam")

  business Business @relation(fields: [businessId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// CONSENT LOG — Compliance tracking
//////////////////////////////////////////////////////

model ConsentLog {
  id String @id @default(uuid())

  userId     String?
  businessId String?

  type   String
  status String

  source   String?
  metadata Json?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId])
  @@index([businessId])
  @@index([type])
}

//////////////////////////////////////////////////////
// CONTRACT — Customer agreement
//////////////////////////////////////////////////////

model Contract {
  id String @id @default(uuid())

  businessId String
  customerId String

  contractNumber String @unique

  customerName  String
  customerPhone String

  title       String
  description String?

  totalValue        Int
  downPayment       Int
  balance           Int
  installmentAmount Int
  totalInstallments Int

  paidAmount        Int @default(0)
  outstandingAmount Int

  frequency  InstallmentFrequency
  customDays Int?

  startDate DateTime
  endDate   DateTime?

  status ContractStatus @default(DRAFT)

  activatedAt  DateTime?
  completedAt  DateTime?
  terminatedAt DateTime?

  terminationReason String?
  terminatedBy      String?

  requiresApproval Boolean   @default(false)
  approvedBy       String?
  approvedAt       DateTime?

  createdBy String

  customer      Customer              @relation(fields: [customerId], references: [id])
  assets        ContractAsset[]
  schedules     InstallmentSchedule[]
  notifications Notification[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([businessId])
  @@index([customerId])
}

//////////////////////////////////////////////////////
// CONTRACT ASSET — Items in contract
//////////////////////////////////////////////////////

model ContractAsset {
  id String @id @default(uuid())

  contractId String

  name      String
  quantity  Int
  unitPrice Int

  contract Contract @relation(fields: [contractId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([contractId])
}

//////////////////////////////////////////////////////
// COUPON — Discount definitions
//////////////////////////////////////////////////////

model Coupon {
  id   String @id @default(uuid())
  code String @unique

  type  String
  value Decimal

  maxUsage   Int?
  usageCount Int  @default(0)

  maxUsagePerBusiness Int?

  validFrom DateTime?
  validTo   DateTime?

  isActive Boolean @default(true)

  couponUsages  CouponUsage[]
  subscriptions Subscription[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// COUPON USAGE — Coupon usage per business
//////////////////////////////////////////////////////

model CouponUsage {
  id String @id @default(uuid())

  couponId String
  coupon   Coupon @relation(fields: [couponId], references: [id])

  businessId String

  usedAt DateTime @default(now())

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// CUSTOMER — End users under business
//////////////////////////////////////////////////////

model Customer {
  id String @id @default(uuid())

  businessId String
  fullName   String
  phone      String
  altPhone   String?
  email      String?

  gender      String?
  dateOfBirth DateTime?

  addressLine String?
  ward        String?
  district    String?
  region      String?

  nationalId String?
  idType     String?
  idVerified Boolean @default(false)

  occupation    String?
  employerName  String?
  monthlyIncome Int?

  guarantorName  String?
  guarantorPhone String?
  relationship   String?

  status CustomerStatus

  totalContracts   Int @default(0)
  activeContracts  Int @default(0)
  totalPaid        Int @default(0)
  totalOutstanding Int @default(0)

  lastPaymentAt DateTime?

  riskScore Int?

  isBlacklisted Boolean @default(false)

  notes String?

  pinHash      String?
  otpHash      String?
  otpExpiresAt DateTime?

  lastLoginAt DateTime?

  business      Business       @relation(fields: [businessId], references: [id])
  contracts     Contract[]
  notifications Notification[]
  dataRequests  DataRequest[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([phone, businessId])
}

//////////////////////////////////////////////////////
// CUSTOMER CREDIT — Credit balance per customer
//////////////////////////////////////////////////////

model CustomerCredit {
  id String @id @default(uuid())

  businessId String
  customerId String

  balance Int @default(0)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([businessId, customerId])
}

//////////////////////////////////////////////////////
// CUSTOMER IMPORT LOG — Bulk import tracking
//////////////////////////////////////////////////////

model CustomerImportLog {
  id String @id @default(uuid())

  businessId String
  fileName   String

  totalRows Int
  imported  Int
  skipped   Int

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([businessId])
}

//////////////////////////////////////////////////////
// DASHBOARD ASSET METRIC — Asset analytics
//////////////////////////////////////////////////////

model DashboardAssetMetric {
  id String @id @default(uuid())

  businessId String
  assetId    String

  soldCount  Int
  totalValue Int
  overdue    Int

  snapshotDate DateTime

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([businessId])
  @@index([assetId])
}

//////////////////////////////////////////////////////
// DASHBOARD HEALTH — Business health score
//////////////////////////////////////////////////////

model DashboardHealth {
  id String @id @default(uuid())

  businessId String

  collectionRate Float
  overdueRatio   Float
  churnRate      Float
  healthScore    Float

  snapshotDate DateTime

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([businessId, snapshotDate])
}

//////////////////////////////////////////////////////
// DASHBOARD INSIGHT — Smart insights
//////////////////////////////////////////////////////

model DashboardInsight {
  id String @id @default(uuid())

  businessId String

  type       String
  messageKey String
  payload    Json?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([businessId])
}

//////////////////////////////////////////////////////
// DASHBOARD SNAPSHOT — Daily metrics
//////////////////////////////////////////////////////

model DashboardSnapshot {
  id String @id @default(uuid())

  businessId   String
  snapshotDate DateTime

  portfolio   Int
  collected   Int
  outstanding Int
  overdue     Int

  cashflow30 Int
  cashflow60 Int
  cashflow90 Int

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([businessId, snapshotDate])
  @@index([businessId])
}

//////////////////////////////////////////////////////
// DASHBOARD STAFF METRIC — Staff performance
//////////////////////////////////////////////////////

model DashboardStaffMetric {
  id String @id @default(uuid())

  businessId String
  staffId    String

  collected  Int
  overdue    Int
  efficiency Float

  snapshotDate DateTime

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([businessId])
  @@index([staffId])
}

//////////////////////////////////////////////////////
// DATA EXPORT STORAGE — Export payload storage
//////////////////////////////////////////////////////

model DataExportStorage {
  id String @id @default(uuid())

  dataRequestId String
  payload       Json

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// DATA REQUEST — Export / delete requests
//////////////////////////////////////////////////////

model DataRequest {
  id String @id @default(uuid())

  type   DataRequestType
  status DataRequestStatus @default(PENDING)

  requestedByAdminId String?
  requestedByAdmin   SystemAdmin? @relation("RequestedByAdmin", fields: [requestedByAdminId], references: [id])

  requestedByUserId String?
  requestedByUser   User?   @relation(fields: [requestedByUserId], references: [id])

  requestedByCustomerId String?
  requestedByCustomer   Customer? @relation(fields: [requestedByCustomerId], references: [id])

  targetType String
  targetId   String

  exportFilePath String?

  reason String?

  approvedById String?
  approvedBy   SystemAdmin? @relation("ApprovedBy", fields: [approvedById], references: [id])

  approvedAt  DateTime?
  processedAt DateTime?

  purgeQueues PurgeQueue[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// DATA RETENTION POLICY — Retention rules
//////////////////////////////////////////////////////

model DataRetentionPolicy {
  id String @id @default(uuid())

  resource      String
  retentionDays Int
  isActive      Boolean @default(true)
  version       Int     @default(1)

  createdById String
  createdBy   SystemAdmin @relation(fields: [createdById], references: [id])

  policyVersions PolicyVersion[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([resource])
}

//////////////////////////////////////////////////////
// DEAD JOB — Failed background jobs
//////////////////////////////////////////////////////

model DeadJob {
  id String @id @default(uuid())

  jobName    String
  instanceId String
  reason     String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// DEVICE TOKEN — Push notification tokens
//////////////////////////////////////////////////////

model DeviceToken {
  id String @id @default(uuid())

  token    String @unique
  platform String

  userId     String?
  customerId String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId])
  @@index([customerId])
}

//////////////////////////////////////////////////////
// FINANCIAL ADJUSTMENT — Credit/Debit adjustments
//////////////////////////////////////////////////////

model FinancialAdjustment {
  id String @id @default(uuid())

  businessId String
  amount     Decimal

  type   String
  reason String?

  createdBy String

  isApplied        Boolean   @default(false)
  appliedPaymentId String?
  appliedAt        DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// GATEWAY HEALTH — Payment gateway monitoring
//////////////////////////////////////////////////////

model GatewayHealth {
  id String @id @default(uuid())

  code      String        @unique
  status    GatewayStatus @default(UNKNOWN)
  lastCheck DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// INSTALLMENT SCHEDULE — Payment schedule
//////////////////////////////////////////////////////

model InstallmentSchedule {
  id String @id @default(uuid())

  contractId String

  dueDate DateTime
  amount  Int

  status ScheduleStatus @default(DUE)

  paidAt DateTime?

  contract Contract @relation(fields: [contractId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([contractId])
}

//////////////////////////////////////////////////////
// JOB LOCK — Distributed job locking
//////////////////////////////////////////////////////

model JobLock {
  id String @id @default(cuid())

  jobName     String   @unique
  lockedAt    DateTime
  lockedUntil DateTime
  instanceId  String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([lockedUntil])
}

//////////////////////////////////////////////////////
// LOGIN ACTIVITY — Login tracking
//////////////////////////////////////////////////////

model LoginActivity {
  id String @id @default(uuid())

  userId  String?
  adminId String?

  status    String
  ipAddress String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// NOTIFICATION — System notifications
//////////////////////////////////////////////////////

model Notification {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id])

  type    String
  channel String

  title   String
  message String

  status String

  retryCount       Int   @default(0)
  providerResponse Json?

  sentAt DateTime?
  readAt DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([businessId])
  @@index([customerId])
  @@index([userId])
}

//////////////////////////////////////////////////////
// NOTIFICATION ESCALATION RULE — Overdue escalation
//////////////////////////////////////////////////////

model NotificationEscalationRule {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  daysOverdue  Int
  roleToNotify String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([businessId, daysOverdue])
}

//////////////////////////////////////////////////////
// NOTIFICATION SETTING — User preferences
//////////////////////////////////////////////////////

model NotificationSetting {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  enableInApp    Boolean @default(true)
  enablePush     Boolean @default(true)
  enableSMS      Boolean @default(true)
  enableWhatsApp Boolean @default(true)
  enableEmail    Boolean @default(true)

  daysBeforeDue Int @default(3)

  muteOverdue   Boolean @default(false)
  muteReminders Boolean @default(false)

  quietHoursStart String?
  quietHoursEnd   String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([businessId, userId])
}

//////////////////////////////////////////////////////
// NOTIFICATION TEMPLATE — Message templates
//////////////////////////////////////////////////////

model NotificationTemplate {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  type   String
  locale String

  title String @db.VarChar(120)
  body  String @db.VarChar(500)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([businessId, type, locale])
}

//////////////////////////////////////////////////////
// PAYMENT — Customer payments
//////////////////////////////////////////////////////

model Payment {
  id String @id @default(uuid())

  businessId String
  contractId String
  customerId String

  amount         Int
  channel        String
  source         String
  reference      String?
  idempotencyKey String?

  receivedAt DateTime

  balanceBefore Int
  balanceAfter  Int

  status PaymentStatus @default(POSTED)

  attachments Json?

  recordedBy String

  reversals PaymentReversal[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([businessId, idempotencyKey])
  @@index([businessId])
}

//////////////////////////////////////////////////////
// PAYMENT REVERSAL — Reversal operations
//////////////////////////////////////////////////////

model PaymentReversal {
  id String @id @default(uuid())

  paymentId String
  reason    String

  requestedBy String
  approvedBy  String?

  status ReversalStatus @default(PENDING)

  approvedAt DateTime?

  Payment Payment @relation(fields: [paymentId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// PERMISSION — System permissions
//////////////////////////////////////////////////////

model Permission {
  id String @id @default(uuid())

  module String
  action String
  scope  String

  rolePermissions RolePermission[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([module, action, scope])
}

//////////////////////////////////////////////////////
// POLICY VERSION — Policy history
//////////////////////////////////////////////////////

model PolicyVersion {
  id String @id @default(uuid())

  policyId String
  policy   DataRetentionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  resource      String
  retentionDays Int
  version       Int

  createdById String
  createdBy   SystemAdmin @relation(fields: [createdById], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([policyId])
}

//////////////////////////////////////////////////////
// PURGE QUEUE — Deletion jobs
//////////////////////////////////////////////////////

model PurgeQueue {
  id String @id @default(uuid())

  dataRequestId String
  dataRequest   DataRequest @relation(fields: [dataRequestId], references: [id], onDelete: Cascade)

  status   PurgeStatus @default(PENDING)
  attempts Int         @default(0)

  lastError String?

  startedAt   DateTime?
  completedAt DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([status])
}

//////////////////////////////////////////////////////
// REFRESH TOKEN — Auth tokens
//////////////////////////////////////////////////////

model RefreshToken {
  id String @id @default(uuid())

  token String @unique

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  customerId String?

  expiresAt       DateTime
  revokedAt       DateTime?
  replacedByToken String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// REPORT EXPORT — Export tracking
//////////////////////////////////////////////////////

model ReportExport {
  id String @id @default(uuid())

  type   String
  format String
  status String

  filePath String?

  requestedBy String
  completedAt DateTime?

  admin SystemAdmin @relation(fields: [requestedBy], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// ROLE PERMISSION — Role mapping
//////////////////////////////////////////////////////

model RolePermission {
  id String @id @default(uuid())

  role         AdminRole
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  systemAdminRoleId String?
  systemAdminRole   SystemAdminRole? @relation(fields: [systemAdminRoleId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([role, permissionId])
}

//////////////////////////////////////////////////////
// SECURITY INCIDENT — Security tracking
//////////////////////////////////////////////////////

model SecurityIncident {
  id String @id @default(uuid())

  type        String
  title       String
  description String

  severity String
  status   String

  source      String
  referenceId String?

  metadata Json?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([type])
  @@index([status])
  @@index([severity])
  @@index([referenceId])
}

//////////////////////////////////////////////////////
// SUBSCRIPTION — Business subscription
//////////////////////////////////////////////////////

model Subscription {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  packageId String
  package   SubscriptionPackage @relation(fields: [packageId], references: [id])

  billingCycle BillingCycle

  setupFeeSnapshot     Int
  priceMonthlySnapshot Int
  priceYearlySnapshot  Int

  featuresSnapshot Json?
  limitsSnapshot   Json?

  status SubscriptionStatus

  startDate  DateTime
  endDate    DateTime?
  graceUntil DateTime?

  setupFeePaid Boolean @default(false)

  version       Int @default(1)
  creditBalance Int @default(0)

  couponId       String
  couponCode     String?
  couponDiscount Int?
  finalAmount    Int?

  coupon Coupon? @relation(fields: [couponId], references: [id])

  subscriptionPayments  SubscriptionPayment[]
  subscriptionHistories SubscriptionHistory[]

  isTrial        Boolean   @default(false)
  trialStartedAt DateTime?
  trialEndedAt   DateTime?
  convertedAt    DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([businessId])
  @@index([status])
  @@index([businessId, status])
  @@index([businessId, createdAt])
}

//////////////////////////////////////////////////////
// SUBSCRIPTION HISTORY — Changes tracking
//////////////////////////////////////////////////////

model SubscriptionHistory {
  id String @id @default(uuid())

  subscriptionId String
  businessId     String

  oldPackageId String?
  newPackageId String?

  oldPrice Int?
  newPrice Int?

  changeType String

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  business     Business     @relation(fields: [businessId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([subscriptionId])
  @@index([businessId])
  @@index([changeType])
}

//////////////////////////////////////////////////////
// SUBSCRIPTION PACKAGE — Plans
//////////////////////////////////////////////////////

model SubscriptionPackage {
  id String @id @default(uuid())

  name        String
  code        String  @unique
  description String?

  priceMonthly Int
  priceYearly  Int?
  setupFee     Int  @default(0)
  trialDays    Int  @default(0)

  features Json
  limits   Json?

  isActive Boolean @default(true)

  subscriptions Subscription[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// SUBSCRIPTION PAYMENT — Payment records
//////////////////////////////////////////////////////

model SubscriptionPayment {
  id String @id @default(uuid())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  couponId String?

  amount   Decimal
  currency String

  status SubscriptionPaymentStatus

  type    String
  gateway String?

  paidAt DateTime?

  invoiceUrl    String?
  webhookStatus String?

  adminOverride Boolean @default(false)

  gatewayPayload Json?
  retryCount     Int   @default(0)
  metadata       Json?

  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// SUBSCRIPTION USAGE — Usage tracking
//////////////////////////////////////////////////////

model SubscriptionUsage {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  metric String
  period String
  value  Int    @default(0)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([businessId, metric, period])
  @@index([businessId])
  @@index([metric])
}

//////////////////////////////////////////////////////
// SUSPICIOUS ACTIVITY — Risk tracking
//////////////////////////////////////////////////////

model SuspiciousActivity {
  id String @id @default(uuid())

  adminId  String?
  action   String
  ip       String?
  endpoint String?
  meta     Json?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([adminId])
  @@index([action])
}

//////////////////////////////////////////////////////
// SYSTEM ADMIN — Platform admins
//////////////////////////////////////////////////////

model SystemAdmin {
  id String @id @default(uuid())

  email    String @unique
  password String

  roleId String
  role   SystemAdminRole @relation(fields: [roleId], references: [id])

  status AdminStatus

  loginAttempts Int       @default(0)
  lockUntil     DateTime?

  forcePasswordChange Boolean @default(false)

  mfaEnabled Boolean @default(false)
  mfaSecret  String?

  tokenVersion Int @default(0)

  requestedDataRequests DataRequest[] @relation("RequestedByAdmin")
  approvedDataRequests  DataRequest[] @relation("ApprovedBy")

  sessions              AdminSession[]
  reportExports         ReportExport[]
  dataRetentionPolicies DataRetentionPolicy[]
  policyVersions        PolicyVersion[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// SYSTEM ADMIN ROLE — Roles
//////////////////////////////////////////////////////

model SystemAdminRole {
  id String @id @default(uuid())

  name     AdminRole @unique
  isActive Boolean   @default(true)

  permissions RolePermission[]
  admins      SystemAdmin[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// SYSTEM ERROR — Individual error
//////////////////////////////////////////////////////

model SystemError {
  id String @id @default(uuid())

  groupId     String
  stack       String?
  environment String

  group SystemErrorGroup @relation(fields: [groupId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([groupId])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// SYSTEM ERROR GROUP — Aggregated errors
//////////////////////////////////////////////////////

model SystemErrorGroup {
  id String @id @default(uuid())

  signature String @unique
  message   String

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt
  occurrence  Int      @default(1)

  errors SystemError[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// SYSTEM HEALTH SNAPSHOT — Health metrics
//////////////////////////////////////////////////////

model SystemHealthSnapshot {
  id String @id @default(uuid())

  dbStatus        String
  lastJobRunAt    DateTime?
  failedJobsCount Int       @default(0)
  errorRate       Float     @default(0)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([createdAt])
}

//////////////////////////////////////////////////////
// SYSTEM JOB LOG — Job execution logs
//////////////////////////////////////////////////////

model SystemJobLog {
  id String @id @default(uuid())

  jobName String
  status  String

  startedAt    DateTime
  finishedAt   DateTime?
  durationMs   Int?
  errorMessage String?

  retryCount    Int       @default(0)
  lastRetriedAt DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([jobName])
  @@index([status])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// SYSTEM SEED LOG — Seed tracking
//////////////////////////////////////////////////////

model SystemSeedLog {
  id String @id @default(uuid())

  key       String    @unique
  status    String
  lastRunAt DateTime?
  error     String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// SYSTEM SETTING — Global config
//////////////////////////////////////////////////////

model SystemSetting {
  id String @id @default("SYSTEM")

  currency             String
  activePaymentGateway String @default("SELCOM")

  isBootstrapped Boolean @default(false)

  maxLoginAttempts Int @default(5)
  lockTimeMinutes  Int @default(15)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// TICKET — Support tickets
//////////////////////////////////////////////////////

model Ticket {
  id String @id @default(uuid())

  businessId      String
  userId          String?
  assignedAdminId String?

  subject     String
  description String

  status   String
  priority String

  slaDeadline DateTime?
  escalated   Boolean   @default(false)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([businessId])
  @@index([status])
}

//////////////////////////////////////////////////////
// TICKET ATTACHMENT — Files
//////////////////////////////////////////////////////

model TicketAttachment {
  id String @id @default(uuid())

  ticketId String
  fileUrl  String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([ticketId])
}

//////////////////////////////////////////////////////
// TICKET MESSAGE — Conversations
//////////////////////////////////////////////////////

model TicketMessage {
  id String @id @default(uuid())

  ticketId   String
  senderId   String
  senderType String
  message    String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([ticketId])
}

//////////////////////////////////////////////////////
// TICKET NOTE — Internal notes
//////////////////////////////////////////////////////

model TicketNote {
  id String @id @default(uuid())

  ticketId String
  adminId  String
  note     String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([ticketId])
}

//////////////////////////////////////////////////////
// USER — Core auth users
//////////////////////////////////////////////////////

model User {
  id String @id @default(uuid())

  name      String?
  phone     String?
  createdBy String?

  email        String
  passwordHash String

  role   UserRole
  status UserStatus

  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  passwordResetToken   String?
  passwordResetExpires DateTime?

  lastLoginAt DateTime?

  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?

  emailVerified      Boolean   @default(false)
  emailVerifyToken   String?
  emailVerifyExpires DateTime?

  refreshTokens        RefreshToken[]
  notifications        Notification[]
  notificationSettings NotificationSetting[]
  dataRequests         DataRequest[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([email, businessId])
}

//////////////////////////////////////////////////////
// ENUMS — DIJITOPAY (SORTED A → Z)
//////////////////////////////////////////////////////

enum AdminRole {
  FINANCE_ADMIN
  OPERATIONS_ADMIN
  READ_ONLY_AUDITOR
  SECURITY_ADMIN
  SUPER_ADMIN
  SUPPORT_ADMIN
}

enum AdminStatus {
  ACTIVE
  SUSPENDED
}

enum AnnouncementEventType {
  BILLING
  GENERAL
  HOLIDAY
  PROMOTION
  SECURITY
  SYSTEM
}

enum AnnouncementPlacement {
  BANNER
  CENTER_MODAL
  INLINE
  SIDEBAR
  TOP_BAR
}

enum ApprovalStatus {
  APPROVED
  PENDING
  REJECTED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum BusinessStatus {
  ACTIVE
  GRACE
  PENDING
  SUSPENDED
  TERMINATED
}

enum ContractAction {
  COMPLETE
  CREATE
  TERMINATE
  UPDATE
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  DRAFT
  TERMINATED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum DataRequestStatus {
  APPROVED
  COMPLETED
  FAILED
  PENDING
  PROCESSING
  REJECTED
}

enum DataRequestType {
  DELETE
  EXPORT
}

enum GatewayStatus {
  DEGRADED
  DOWN
  HEALTHY
  UNKNOWN
}

enum InstallmentFrequency {
  CUSTOM
  DAILY
  MONTHLY
  WEEKLY
}

enum PaymentStatus {
  POSTED
  REVERSED
}

enum PurgeStatus {
  COMPLETED
  FAILED
  PENDING
  PROCESSING
}

enum ReversalStatus {
  APPROVED
  PENDING
  REJECTED
}

enum ScheduleStatus {
  DUE
  PAID
}

enum SubscriptionPaymentMethod {
  AIRTEL
  MPESA
  SELCOM
}

enum SubscriptionPaymentStatus {
  CONFIRMED
  FAILED
  PENDING
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  GRACE
  SUSPENDED
  TRIAL
}

enum UserRole {
  BUSINESS_OWNER
  CUSTOMER
  MANAGER
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}
